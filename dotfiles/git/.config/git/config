# This is Git's per-user configuration file.
[user]
	name = Luke OMalley
	email = luke@lukeomalley.xyz
	signingkey = /Users/luke/.ssh/id_ed25519


[gpg]
    format = ssh 

[core]
	pager = delta
	autocrlf = input
	compression = 9  
	fsync = none
	editor = nvim
	whitespace = error

[color]
	ui = true

[interactive]
	diffFilter = delta --color-only

[commit]
	gpgSign = true

[push]
	autoSetupRemote = true
	default = current
	followTags = true
	gpgSign = false

[status]
	branch = true
	short = true
	showStash = true
	showUntrackedFiles = all

[pull]
	rebase = true

[blame]
	coloring = highlightRecent
	date = relative

[log]
	abbrevCommit = true  # short commits
	graphColors = blue,yellow,cyan,magenta,green,red

[delta]
	navigate = true            # n/N jumps between files (CLI only, not in lazygit)
	dark = true
	tabs = 4
	line-numbers = true
	hyperlinks = true
	zero-style = dim syntax    # dim unchanged context lines
	hunk-header-style = file line-number syntax
	hunk-header-decoration-style = none   # drop the box/underline for a cleaner header
	file-style = bold yellow
	file-decoration-style = none          # no heavy underline under file names
	# side-by-side = true  # uncomment for split view instead of inline

[init]
	defaultBranch = main

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[rerere]
	enabled = true

[merge]
	conflictStyle = zdiff3

[gpg "ssh"]
	allowedSignersFile = /Users/luke/.ssh/allowed_signers
