#!/bin/bash

set -euo pipefail

readonly IMAGE_NAME="mcp/firecrawl:latest"
readonly CONTAINER_NAME="firecrawl-mcp-server"
readonly HOST_PORT=3015

if ! command -v op &> /dev/null; then
    echo "Error: 1Password CLI (op) is not installed or not in PATH." >&2
    exit 1
fi

if ! command -v docker &> /dev/null; then
    echo "Error: docker is not installed or not in PATH." >&2
    exit 1
fi

# Vault: Personal, Item: FIRECRAWL_API_KEY, Field: credential
API_KEY=$(op read "op://Personal/FIRECRAWL_API_KEY/credential")

if [ -z "$API_KEY" ]; then
    echo "Error: Failed to retrieve FIRECRAWL_API_KEY from 1Password." >&2
    exit 1
fi

echo "Pulling latest $IMAGE_NAME..."
docker pull "$IMAGE_NAME"

docker rm -f "$CONTAINER_NAME" &>/dev/null || true

echo "Starting Firecrawl MCP Server (streamable HTTP) on localhost:$HOST_PORT..."

docker run -d \
  --name "$CONTAINER_NAME" \
  --restart unless-stopped \
  -p "$HOST_PORT:3015" \
  -e FIRECRAWL_API_KEY="$API_KEY" \
  -e PORT=3015 \
  -e HOST=0.0.0.0 \
  -e HTTP_STREAMABLE_SERVER=true \
  "$IMAGE_NAME"
