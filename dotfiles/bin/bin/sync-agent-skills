#!/bin/bash
set -euo pipefail

DOTFILES_ROOT="${DOTFILES_ROOT:-$HOME/code/dotfiles}"
SOURCE_DIR="${AGENT_SKILLS_SOURCE:-$DOTFILES_ROOT/dotfiles/agents/.agents/skills}"

DEST_DIRS=(
  "$HOME/.agents/skills"
  "$HOME/.claude/skills"
  "$HOME/.cursor/skills"
  "$HOME/.config/opencode/skills"
)

LEGACY_DEST_DIRS=(
  "$HOME/.codex/skills"
)

usage() {
  cat <<'EOF'
Usage: sync-agent-skills [--dry-run]

Sync shared skills from dotfiles into agent skill directories using whole
directory symlinks:
  ~/.agents/skills
  ~/.claude/skills
  ~/.cursor/skills
  ~/.config/opencode/skills

The dotfiles skills directory is authoritative:
  ~/code/dotfiles/dotfiles/agents/.agents/skills

Same-name app-local skills are overwritten with symlinks to the repo source.
This script does not copy, adopt, or import app-local skills back into dotfiles.
EOF
}

DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [[ ! -d "$SOURCE_DIR" ]]; then
  echo "Source skills directory does not exist: $SOURCE_DIR" >&2
  exit 1
fi

SOURCE_DIR="$(cd "$SOURCE_DIR" && pwd)"

run() {
  if [[ "$DRY_RUN" == true ]]; then
    printf 'DRY RUN:'
    printf ' %q' "$@"
    printf '\n'
  else
    "$@"
  fi
}

# Regenerate agents/openai.yaml metadata so apps like Codex can render UI chips
# for every skill. The generator overwrites in place; the files live next to
# SKILL.md and travel with the rest of the skill.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GENERATOR="$SCRIPT_DIR/generate-skill-metadata"
if [[ -x "$GENERATOR" ]]; then
  AGENT_SKILLS_SOURCE="$SOURCE_DIR" run "$GENERATOR"
else
  echo "Generator not found or not executable: $GENERATOR" >&2
fi

sync_to_dest() {
  local dest_dir="$1"
  local skill_dir
  local skill_name
  local target
  local link_target

  run mkdir -p "$dest_dir"

  for skill_dir in "$SOURCE_DIR"/*; do
    [[ -d "$skill_dir" ]] || continue

    skill_name="$(basename "$skill_dir")"
    target="$dest_dir/$skill_name"
    link_target="$(
      python3 -c 'import os, sys; print(os.path.relpath(sys.argv[1], sys.argv[2]))' \
        "$skill_dir" \
        "$dest_dir"
    )"

    if [[ -L "$target" || -e "$target" ]]; then
      echo "Overwriting app-local skill: $target"
      run rm -rf "$target"
    fi

    run ln -s "$link_target" "$target"
  done
}

cleanup_legacy_dest() {
  local dest_dir="$1"
  local skill_dir
  local skill_name
  local target

  [[ -d "$dest_dir" ]] || return 0

  for skill_dir in "$SOURCE_DIR"/*; do
    [[ -d "$skill_dir" ]] || continue
    skill_name="$(basename "$skill_dir")"
    target="$dest_dir/$skill_name"
    if [[ -L "$target" ]]; then
      echo "Removing legacy skill link: $target"
      run rm "$target"
    fi
  done
}

for dest_dir in "${DEST_DIRS[@]}"; do
  sync_to_dest "$dest_dir"
done

for dest_dir in "${LEGACY_DEST_DIRS[@]}"; do
  cleanup_legacy_dest "$dest_dir"
done

echo "Synced shared skills from $SOURCE_DIR"
